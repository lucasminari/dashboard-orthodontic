# Postgres (mesmo banco do Supabase usado pelo dashboard/)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# Kommo CRM
KOMMO_SUBDOMAIN=
KOMMO_ACCESS_TOKEN=
# Segredo HMAC pra validar webhook (configurar do lado do Kommo tambem)
KOMMO_WEBHOOK_SECRET=

# JWT
JWT_SECRET=troque-isto-em-producao
JWT_EXPIRES_IN=24h

# Push notifications (gere com: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@orthodontic.local

# HTTP
PORT=3001
CORS_ORIGIN=http://localhost:3000
